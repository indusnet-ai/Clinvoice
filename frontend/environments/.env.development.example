# Copy to `.env.development` in this directory.
# All three "service" URLs point at the single FastAPI backend on :8020.

VITE_BACKEND_URL=http://localhost:8020
VITE_CLINVOICE_AI_URL=http://localhost:8020
VITE_VOICE_URL=http://localhost:8020
VITE_FILE_UPLOAD_URL=http://localhost:8020
VITE_SSL_URL=http://localhost:8020
VITE_ABHA_URL=http://localhost:8020

# The frontend sends this as the `x-api-key` header on AI calls.
# A row with this value is auto-seeded into api_keys on first signup.
VITE_CLINVOICE_API_KEY=dev-key-123
