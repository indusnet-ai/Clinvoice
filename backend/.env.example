# Copy this file to `.env` (same directory) and fill in real values.
# Required keys are commented "(required)"; everything else has a default.

# (required) OpenAI — powers Whisper transcription + all LLM calls
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4.1
OPENAI_WHISPER_MODEL=whisper-1

# (required) Postgres. Use the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://clinvoice:clinvoice@localhost:5432/clinvoice_db

# Auth / JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Optional — only needed if you wire up the Google-OAuth router.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
